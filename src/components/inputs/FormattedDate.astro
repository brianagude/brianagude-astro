---
interface Props {
  date: Date;
  endDate?: Date;
  format?: 'full' | 'year' | 'month-year';
}

const { date, endDate, format = 'full' } = Astro.props;

const getOrdinal = (day: number) => {
  if (day > 3 && day < 21) return 'th';
  switch (day % 10) {
    case 1:  return "st";
    case 2:  return "nd";
    case 3:  return "rd";
    default: return "th";
  }
};

const formatSingle = (d: Date): string => {
  if (format === 'year') {
    return `${d.getFullYear()}`;
  } else if (format === 'month-year') {
    return d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
  } else {
    const month = d.toLocaleDateString('en-US', { month: 'long' });
    const day = d.getDate();
    const year = d.getFullYear();
    return `${month} ${day}${getOrdinal(day)}, ${year}`;
  }
};

const startStr = formatSingle(date);
const endStr = endDate ? formatSingle(endDate) : null;
const formattedDate = endStr ? `${startStr} – ${endStr}` : startStr;

const isoStart = date.toISOString();
const isoEnd = endDate ? endDate.toISOString() : null;
---

<time datetime={isoEnd ? `${isoStart}/${isoEnd}` : isoStart}>
  {formattedDate}
</time>
