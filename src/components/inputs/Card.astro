---
const { url, title, image, video, date } = Astro.props;
import { Image } from "astro:assets";
import Mux from "./Mux.astro";
import FormattedDate from "./FormattedDate.astro";
import OutboundIcon from "@/images/icons/outbound.svg"
import Link from "@/components/inputs/Link.astro"
---

<Link href={url} aria-label={title} class="card-wrapper">
  <div class="media">
    {video && <Mux playbackId={video} title={title} class="main-video" />}
    {image && !video && <Image src={image.url} alt={image.alt} class="main-img" />}
    <!-- {image && !video && <Image src={OutboundIcon} alt={image.alt} width={18} height={18} />} -->
  </div>
  <div class="content">
    <span class="body-lg title">{title}</span>
    {date && <span class="body-sm"><FormattedDate date={date} /></span>}
  </div>
</Link>

<style lang="scss">
  @use "@/styles/_variables.scss" as *;

  .body-sm {
    opacity: 0.5;
  }

  a {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: all 0.3s ease-in-out;

    &:hover {
      .media {
        transform: translate(-4px, -4px);
        box-shadow: 4px 4px 0px rgba(4,6,2,0.25);
        border-radius: 40px;
        
      }

      .title {
        font-weight: 700;
      }
    }
  }

  .media {
    aspect-ratio: 16/9;
    border-radius: 24px;
    border: 1px solid $black;
    transition: all 0.2s ease-in-out;
    overflow: hidden;
  }
  
  // @media (hover: hover) {
  //   :global(.container):has(a:hover) a:not(:hover) {
  //       filter: blur(4px);
  //     }
  // }

  img, video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content {
    display: flex;
    flex-direction: column;
    text-align: center; 
  }

  span {
    transition: all 0.3s ease-in-out;
  }
</style>