---
const { playbackId, title } = Astro.props;
const poster = `https://image.mux.com/${playbackId}/thumbnail.jpg`;
---

<div class="mux-wrapper" style={`background-image: url('${poster}')`}>
  <mux-player
    playback-id={playbackId}
    metadata-video-title={title}
    poster={poster}
    autoPlay="muted"
    loop
    muted
    nohotkeys
  ></mux-player>
</div>

<style>
  .mux-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }

  mux-player {
    width: 100%;
    height: 100%;
  }
</style>
