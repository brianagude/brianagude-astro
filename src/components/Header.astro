---
import Navigation from "./inputs/Navigation.astro";

const links = [
  
	{
		text: "everything",
		url: "/",
	},
  {
		text: "experiments",
		url: "/experiments",
	},
  {
		text: "case studies",
		url: "/case-studies",
	},
  {
		text: "work",
		url: "/work",
	},
  // {
	// 	text: "thoughts",
	// 	url: "/thoughts",
	// },
  {
		text: "about",
		url: "/about",
	},
];
---
<header transition:persist>
  <div class="container">
    <Navigation links={links} ariaLabel="Main navigation" />
  </div>
</header>

<style lang="scss">
  @use "@/styles/_variables.scss" as *;

  header {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 50;

    img {
      border: 1px solid $black;
      border-radius: 100%;
    }
  }

  .container {
    padding: 8px 16px;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    max-width: $bp-xl;
    margin: 0 auto;
  }

  .logo {
    display: flex;
    flex-direction: column; 
    align-items: center;
    gap: 12px;
    display: none;

    @include mq("md") { 
      display: inline-block;
    }
  }

  p { line-height: 1.2; }
  a { line-height: 1; }
  b { font-weight: 500; }
</style>