---
const { url, title, date } = Astro.props;

import FormattedDate from "@/components/inputs/FormattedDate.astro";
---
<a href={url}>
    <span class="h4">{title}</span><br/><span class="body-sm"><FormattedDate date={date} /></span>
</a>

<style lang="scss">
    @use "@/styles/_variables.scss" as *;

    .body-sm {
        opacity: 0.5;
    }

  a {
    display: block;
    font-weight: 500;
    // font-size: inherit;
    padding: 0 8px;
    border-radius: 24px;
    background: color-mix(in oklab, var(--color-black) 5%, transparent);
    backdrop-filter: blur(4px);
    transition: background ease 0.2s;
    padding: 16px 24px;

    &:hover {
      background-color: $primary-color;
    }
  }
</style>