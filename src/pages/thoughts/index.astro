---
import { getCollection } from "astro:content";

import Card from "@/components/inputs/Card.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const allPosts = await getCollection("thoughts");
const sortedPosts = allPosts.sort((a, b) => 
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const pageTitle = "briana's thoughts";
---

<BaseLayout title={pageTitle}>
  <section class="page-section">
    <div class="container grid">
      {sortedPosts.sort().map((post: any) => <Card url={`/thoughts/${post.id}/`} title={post.data.title} image={post.data.image} date={post.data.pubDate} />)}
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use "@/styles/_components.scss" as *;
	@use "@/styles/_variables.scss" as *;
</style>